lblGenStatus text

=With({
    fechaInicio: ThisItem.SowingMaleExp;
    fechaFin: Coalesce(ThisItem.ShippingExp; ThisItem.SPAExp);
    hoy: Today()
};
    With({
        diasTranscurridos: If(IsBlank(fechaInicio); 0; DateDiff(fechaInicio; hoy; TimeUnit.Days));
        diasTotales: If(IsBlank(fechaInicio) Or IsBlank(fechaFin); 0; DateDiff(fechaInicio; fechaFin; TimeUnit.Days));
        diasFaltantes: If(IsBlank(fechaFin); 0; DateDiff(hoy; fechaFin; TimeUnit.Days));
        etapaActual: Switch(true;
            !IsBlank(ThisItem.ShippingReal); "Finalizado";
            !IsBlank(ThisItem.SPAReal); "Shipping";
            !IsBlank(ThisItem.FingerprintSeedsReal); "SPA";
            !IsBlank(ThisItem.ProcessingReal); "Fingerprint semillas";
            !IsBlank(ThisItem.HarvestLastReal); "Procesamiento";
            !IsBlank(ThisItem.HarvestFirstReal); "Última cosecha";
            !IsBlank(ThisItem.MiniprintReal); "Primera cosecha";
            !IsBlank(ThisItem.PolEndReal); "Miniprint";
            !IsBlank(ThisItem.PolStartReal); "Polinización fin";
            !IsBlank(ThisItem.TissuePostReal); "Polinización inicio";
            !IsBlank(ThisItem.TransplantReal); "Tissue post-planting";
            !IsBlank(ThisItem.FingerprintTissueReal); "Trasplante";
            !IsBlank(ThisItem.TissuePreReal); "Fingerprint tejido";
            !IsBlank(ThisItem.SowingFemReal); "Tissue pre-planting";
            !IsBlank(ThisItem.SowingMaleReal); 
                If(ThisItem.Crop.Value = "Cucumber"; "Siembra hembra"; "Tissue pre-planting");
            !IsBlank(ThisItem.SowingMaleExp); "Siembra macho";
            "Sin iniciar"
        )
    };
        If(IsBlank(fechaInicio);
            "Sin iniciar";
            If(diasTotales = 0;
                "Día " & diasTranscurridos & " · " & etapaActual;
                "Día " & diasTranscurridos & "/" & diasTotales & " · " & etapaActual & 
                If(diasFaltantes > 0; " · Faltan " & diasFaltantes & "d";
                   diasFaltantes = 0; " · Hoy!";
                   " · Atrasado " & Abs(diasFaltantes) & "d"
                )
            )
        )
    )
)



