=If(IsBlank(EstStart_Sowing.SelectedDate);
    Notify("Selecciona una fecha válida"; NotificationType.Error);
    With({
        fechaBase: EstStart_Sowing.SelectedDate;
        cfg: LookUp(colPhenoConfig;
            Upper(Trim(Coalesce(Crop.Value; ""))) = Upper(Trim(Coalesce(ThisItem.Crop.Value; ""))) And
            Upper(Trim(Coalesce(Generation; ""))) = Upper(Trim(Coalesce(ThisItem.Generation.Value; ""))) And
            Upper(Trim(Coalesce(Area.Value; ""))) = Upper(Trim(Coalesce(ThisItem.Area.Value; ""))) And
            (
                IsBlank(MCT) Or
                Upper(Trim(MCT)) = Upper(Trim(Coalesce(ThisItem.MCT.Value; "")))
            ) And
            (
                IsBlank(Program) Or
                Upper(Trim(Program)) = Upper(Trim(Coalesce(ThisItem.Program.Value; "")))
            )
        )
    };
        If(IsBlank(cfg);
            Notify(
                "No hay configuración fenológica para Crop=" & ThisItem.Crop.Value & 
                " | Gen=" & Coalesce(ThisItem.Generation.Value; "?") & 
                " | Area=" & Coalesce(ThisItem.Area.Value; "?") & 
                " | MCT=" & Coalesce(ThisItem.MCT.Value; "?") & 
                " | Program=" & Coalesce(ThisItem.Program.Value; "?"); 
                NotificationType.Error
            );
            Patch(DATASUMMARY;
                LookUp(DATASUMMARY; ID = ThisItem.ID);
                {
                    SowingMaleExp:        fechaBase;
                    SowingFemExp:         DateAdd(fechaBase; Coalesce(cfg.SowingFemOffset; 0); TimeUnit.Days);
                    TissuePreExp:         DateAdd(fechaBase; Coalesce(cfg.TissuePreOffset; 0); TimeUnit.Days);
                    FingerprintTissueExp: DateAdd(fechaBase; Coalesce(cfg.FingerprintTissueOffset; 0); TimeUnit.Days);
                    TransplantExp:        DateAdd(fechaBase; Coalesce(cfg.TransplantOffset; 0); TimeUnit.Days);
                    TissuePostExp:        DateAdd(fechaBase; Coalesce(cfg.TissuePostOffset; 0); TimeUnit.Days);
                    PolStartExp:          DateAdd(fechaBase; Coalesce(cfg.PolStartOffset; 0); TimeUnit.Days);
                    PolEndExp:            DateAdd(fechaBase; Coalesce(cfg.PolEndOffset; 0); TimeUnit.Days);
                    MiniprintExp:         DateAdd(fechaBase; Coalesce(cfg.MiniprintOffset; 0); TimeUnit.Days);
                    HarvestFirstExp:      DateAdd(fechaBase; Coalesce(cfg.HarvestFirstOffset; 0); TimeUnit.Days);
                    HarvestLastExp:       DateAdd(fechaBase; Coalesce(cfg.HarvestLastOffset; 0); TimeUnit.Days);
                    ProcessingExp:        DateAdd(fechaBase; Coalesce(cfg.ProcessingOffset; 0); TimeUnit.Days);
                    FingerprintSeedsExp:  DateAdd(fechaBase; Coalesce(cfg.FingerprintSeedsOffset; 0); TimeUnit.Days);
                    SPAExp:               DateAdd(fechaBase; Coalesce(cfg.SPAOffset; 0); TimeUnit.Days);
                    ShippingExp:          DateAdd(fechaBase; Coalesce(cfg.ShippingOffset; cfg.SPAOffset + 7); TimeUnit.Days)
                }
            );
            Refresh(DATASUMMARY);
            ClearCollect(colSets; DATASUMMARY);
            Notify(
                "✅ Fechas calculadas para " & ThisItem.SetName; 
                NotificationType.Success
            )
        )
    )
)


